{
  "name": "@opencae/core-cloud",
  "version": "0.1.0",
  "description": "OpenCAE Core Cloud runner service for static sparse and MDOF dynamic solves.",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run"
  },
  "dependencies": {
    "@opencae/core": "workspace:*",
    "@opencae/solver-cpu": "workspace:*"
  },
  "devDependencies": {
    "@opencae/examples": "workspace:*"
  }
}
