{
  "name": "opencae-core",
  "private": true,
  "version": "0.1.2",
  "description": "Browser-local WebGPU finite element analysis core for web applications.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --sort run build",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "dev": "pnpm --filter @opencae/web dev"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
