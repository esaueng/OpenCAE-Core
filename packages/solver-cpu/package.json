{
  "name": "@opencae/solver-cpu",
  "version": "0.1.0",
  "description": "Dense CPU reference solver backend for OpenCAE Core.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@opencae/core": "workspace:*"
  },
  "devDependencies": {
    "@opencae/examples": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run"
  }
}
