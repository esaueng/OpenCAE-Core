{
  "name": "@opencae/web",
  "version": "0.1.0",
  "description": "Web application shell for OpenCAE Core.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "dev": "vite --host 127.0.0.1"
  },
  "dependencies": {
    "@opencae/core": "workspace:*",
    "@opencae/examples": "workspace:*",
    "@opencae/solver-cpu": "workspace:*",
    "@opencae/solver-webgpu": "workspace:*"
  },
  "devDependencies": {
    "vite": "^6.4.2"
  }
}
